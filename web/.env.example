# Copy this file to `.env.local` (gitignored) and fill in your values.
#
# Create your own Entra app registration first:
#   pwsh -File scripts/create-app-reg.ps1
# That script prints the client id; paste it here.

VITE_AZURE_CLIENT_ID=

# Optional: lock the app to a single tenant (defaults to `common` so any
# Entra user can sign in).
# VITE_AZURE_TENANT_ID=
